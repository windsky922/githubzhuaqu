# 可选：GitHub Token，用于提高 Search API 速率限制。
GH_SEARCH_TOKEN=

# Kimi 兼容的聊天补全 API 配置。
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=
KIMI_TIMEOUT_SECONDS=120

# Telegram 推送配置。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 周报公开访问地址。留空时，GitHub Actions 会根据 GITHUB_REPOSITORY 推导 GitHub Pages 地址。
REPORT_BASE_URL=

# 运行参数。
DAYS_BACK=7
MIN_STARS=20
MAX_PROJECTS=10
